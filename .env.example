# Application Configuration
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=True
APP_NAME=ALIA Platform API
APP_VERSION=1.0.0

# Database Configuration
# ============================================
# SQLite (default - no setup required)
DATABASE_URL=sqlite:///./alia.db

# PostgreSQL Async (Local Development)
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/alia_db

# PostgreSQL Async (Render.com Production)
# DATABASE_URL=postgresql+asyncpg://user:password@hostname.render.com:5432/alia_db

# PostgreSQL Async (with SSL)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/alia_db?sslmode=require
# ============================================

# Redis Configuration (optional - for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# AI Services
OPENAI_API_KEY=your-openai-api-key

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_DIR=uploads
BASE_URL=http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=5

# Logging
LOG_LEVEL=INFO
